# Show CopyQ
"copyq toggle"
    Control+Shift+Mod4+Up

#kill
"bash -c 'wid=$(xdotool getmouselocation --shell | grep WINDOW | cut -d= -f2); if [ -n "$wid" ]; then wmctrl -i -c "$wid"; fi'"
 Control+m:0x40 + b:2

# Debounced Minimize (Meta + Wheel Down)
"~/Dev/config/xbindkeys/meta-wheel-minimize"
  m:0x40 + b:5

# Restore a window that has been minimized (Meta + Wheel Up)
"~/Dev/config/xbindkeys/meta-wheel-restore"
  m:0x40 + b:4

# Mouse Back -> Fish prevd in Terminal, standard Back elsewhere
"if xdotool getactivewindow getwindowname | grep -i 'terminal'; then xte 'keydown Alt_L' 'key Left' 'keyup Alt_L'; else xdotool key XF86Back; fi"
b:8

# Mouse Forward -> Fish nextd in Terminal, standard Forward elsewhere
"if xdotool getactivewindow getwindowname | grep -i 'terminal'; then xte 'keydown Alt_L' 'key Right' 'keyup Alt_L'; else xdotool key XF86Forward; fi"
b:9


