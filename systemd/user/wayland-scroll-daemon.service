[Unit]
Description=Zero-Lag Wayland Scroll Shortcut Daemon
After=graphical-session.target xremap-meta-keyboard.service
Requires=xremap-meta-keyboard.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/lewis/Dev/config/xbindkeys/wayland_scroll_daemon.py
Restart=always
RestartSec=1
Environment=PYTHONUNBUFFERED=1
Environment=XDG_RUNTIME_DIR=/run/user/%U

[Install]
WantedBy=default.target
